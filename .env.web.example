# AKYS web stack environment example
# Copy this file to `.env` on the school server and edit the values.

MEDEK_ENV=production
MEDEK_APP_VERSION=ver_100.1-role-theme-sync
MEDEK_API_SECRET=CHANGE_ME_AUTOGENERATED_BY_START_SCRIPT
MEDEK_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_AUTOGENERATED_BY_START_SCRIPT
MEDEK_API_TOKEN_TTL_MINUTES=480
MEDEK_WEB_PORT=8080

# =========================================================
# Masaüstü Akreditasyon ana klasörü
# =========================================================
# tools/start_web_stack.ps1 çalıştırıldığında otomatik olarak
# masaüstündeki Akreditasyon klasörünün tam yolu ile güncellenir.
# Doğrudan docker compose kullanacaksanız burayı elle ayarlayın.
# Windows örnek: C:/Users/Kullanici/Desktop/Akreditasyon
# Linux/Mac örnek: /home/kullanici/Desktop/Akreditasyon
AKREDITASYON_ROOT=./Akreditasyon

# Add the final intranet URL after DNS is decided.
# Examples:
# MEDEK_CORS_ORIGINS=http://localhost:8080,http://192.168.1.20:8080,http://medek.okul.local
MEDEK_CORS_ORIGINS=http://localhost:8080
MEDEK_TRUSTED_HOSTS=localhost,127.0.0.1,api,web
MEDEK_APP_BASE_URL=http://localhost:8080

MEDEK_LOGIN_MAX_FAILED_ATTEMPTS=5
MEDEK_LOGIN_LOCK_MINUTES=15
MEDEK_RATE_LIMIT_ENABLED=1
MEDEK_RATE_LIMIT_LOGIN_PER_MINUTE=5
MEDEK_RATE_LIMIT_GENERAL_PER_MINUTE=300
MEDEK_RATE_LIMIT_UPLOAD_PER_MINUTE=20
MEDEK_RATE_LIMIT_EXPORT_PER_MINUTE=30
MEDEK_MAX_UPLOAD_MB=50
MEDEK_MAX_BACKUP_MB=10
MEDEK_MAX_REQUEST_BODY_MB=60

# =========================================================
# PostgreSQL production database
# =========================================================
# v128 uses PostgreSQL by default in docker-compose.web.yml.
# Keep MEDEK_DB_BACKEND=sqlite only for legacy/local rollback testing.
MEDEK_DB_BACKEND=postgresql
POSTGRES_DB=medek
POSTGRES_USER=medek
POSTGRES_PASSWORD=CHANGE_ME_AUTOGENERATED_BY_START_SCRIPT
# Leave empty to let the API build a URL-safe internal Docker DSN from the
# POSTGRES_* values. Set only for external PostgreSQL endpoints.
MEDEK_DATABASE_URL=

# SQLite fallback/legacy path. Not used when MEDEK_DB_BACKEND=postgresql.
MEDEK_SQLITE_PATH=/app/medek_data/medek_kys_v7_9.sqlite3

# Optional HTTPS/intranet reverse proxy (docker-compose.https.yml)
MEDEK_DOMAIN=localhost
MEDEK_HTTP_PORT=80
MEDEK_HTTPS_PORT=443

# Export job backend
# background: single-container FastAPI BackgroundTasks
# rq: Redis + RQ worker via docker-compose.queue.yml
MEDEK_JOB_BACKEND=background
MEDEK_REDIS_URL=redis://redis:6379/0
MEDEK_RQ_QUEUE=medek_exports

# Optional SMTP/e-mail notifications for workflow events
MEDEK_MAIL_ENABLED=false
MEDEK_SMTP_HOST=smtp.kurum.edu.tr
MEDEK_SMTP_PORT=587
MEDEK_SMTP_USER=akreditasyon@kurum.edu.tr
MEDEK_SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
MEDEK_SMTP_FROM=Akreditasyon Kalite Yönetimi <akreditasyon@kurum.edu.tr>
MEDEK_SMTP_TLS=true
MEDEK_SMTP_SSL=false
# Set true when MEDEK_APP_BASE_URL uses HTTPS.
MEDEK_COOKIE_SECURE=false

# Offline AI Draft / Ollama integration
MEDEK_AI_ENABLED=false
MEDEK_AI_PROVIDER=ollama
MEDEK_OLLAMA_BASE_URL=http://host.docker.internal:11434
MEDEK_OLLAMA_MODEL=llama3.1
MEDEK_OLLAMA_TIMEOUT=45

# =========================================================
# Multi-Tenant / Kurum-Fakülte İzolasyonu
# =========================================================
# Mevcut tek kurumlu kurulumlar tenant_default altında çalışır.
MEDEK_DEFAULT_TENANT_NAME=Ana Kurum


# =========================================================
# Deployment / Installer Wizard Notes
# =========================================================
# Admin panelindeki Ayarlar & Yedek -> Kurulum Sihirbazı bu değerleri kontrol eder.
# Özellikle MEDEK_APP_BASE_URL, MEDEK_CORS_ORIGINS ve MEDEK_TRUSTED_HOSTS okul içi IP/DNS adresiyle uyumlu olmalıdır.
